{
  "name": "continental-backend",
  "version": "2.0.0",
  "description": "Continental Auto Parts - NestJS backend: public SSR catalog (SEO), superadmin & workers APIs, realtime sync, Prisma ORM",
  "scripts": {
    "build": "prisma generate && nest build",
    "start": "prisma db push --skip-generate --accept-data-loss && node dist/main.js",
    "dev": "nest start --watch",
    "prisma:generate": "prisma generate",
    "test": "jest --config ./test/jest-e2e.json"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.15",
    "@nestjs/core": "^10.4.15",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/mapped-types": "^2.0.6",
    "@nestjs/platform-express": "^10.4.15",
    "@nestjs/platform-socket.io": "^10.4.15",
    "@nestjs/throttler": "^6.4.0",
    "@nestjs/websockets": "^10.4.15",
    "@prisma/client": "^5.22.0",
    "@socket.io/redis-adapter": "^8.3.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "cloudinary": "^1.41.3",
    "compression": "^1.8.1",
    "ioredis": "^5.4.1",
    "multer": "^1.4.5-lts.2",
    "multer-storage-cloudinary": "^4.0.0",
    "pdfkit": "^0.19.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "socket.io": "^4.8.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.9",
    "@nestjs/testing": "^10.4.22",
    "@types/compression": "^1.7.5",
    "@types/express": "^4.17.21",
    "@types/jest": "^30.0.0",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.10.0",
    "@types/pdfkit": "^0.17.6",
    "@types/supertest": "^7.2.1",
    "jest": "^30.4.2",
    "mongodb": "^7.5.0",
    "mongodb-memory-server": "^11.2.0",
    "prisma": "^5.22.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "typescript": "^5.6.3"
  }
}
