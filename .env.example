# MongoDB Atlas connection string. In Atlas: Database -> Connect -> Drivers ->
# copy the string, then replace <password> with your actual database user's
# password, and add a database name in the path. Looks like:
#   mongodb+srv://someuser:somepassword@cluster0.xxxxx.mongodb.net/continental?retryWrites=true&w=majority
DATABASE_URL=

# Cloudinary — from your Cloudinary dashboard home page, the "API Environment
# variable" box. Looks like:
#   cloudinary://123456789012345:AbCdEfGhIjKlMnOpQrStUvWxYz1@your-cloud-name
CLOUDINARY_URL=

# Production settings — set these on your host:
# SITE_URL=https://yourdomain.com
# PORT=4000
# JWT_SECRET=<long random string>
# REDIS_URL=redis://...   (only when running multiple server instances)
