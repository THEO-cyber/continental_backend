# Used by the Prisma CLI (the app itself resolves the absolute path at runtime).
DATABASE_URL="file:../data/continental.db"

# Production settings — set these on your host:
# SITE_URL=https://yourdomain.com
# PORT=4000
# JWT_SECRET=<long random string>
# REDIS_URL=redis://...   (only when running multiple server instances)
# DATABASE_URL=postgresql://user:pass@host:5432/continental   (with provider switched to postgresql)
